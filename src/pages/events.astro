---
import { getEmDashCollection, getEmDashEntry, getSeoMeta, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import { sectionsFrom, sortByOrder } from "../lib/content";
import { resolveStarterSiteIdentity } from "../utils/site-identity";

const setCache = (cacheHint: unknown) => {
	if (Astro.cache?.enabled && cacheHint) Astro.cache.set(cacheHint as any);
};

const pageResult = await getEmDashEntry("pages", "events");
const eventsResult = await getEmDashCollection("events", {
	status: "published",
	orderBy: { sort_order: "asc" },
});

setCache(pageResult.cacheHint);
setCache(eventsResult.cacheHint);

const page = pageResult.entry as any;
if (!page) return Astro.redirect("/404");

const events = sortByOrder(eventsResult.entries as any[]);
const upcoming = events.filter((event) => !event.data.past);
const featured = upcoming.find((event) => event.data.featured) ?? upcoming[0];
const sections = sectionsFrom(page);
const hero = sections.hero ?? {};
const subscribe = sections.subscribe ?? {};
const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());
const seo = getSeoMeta(page, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: "/events",
});
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	active="Events"
	content={{ collection: "pages", id: page.data.id, slug: "events" }}
>
	<section
		class="bgin-section"
		style="padding-top: var(--hero-y); padding-bottom: var(--space-12);"
	>
		<div
			class="bgin-2col-left"
		style="max-width: 1200px; margin: 0 auto; align-items: end;"
		>
			<div>
				<div class="bgin-eyebrow" style="margin-bottom: 24px;" {...page.edit.sections}>
					{hero.eyebrow}
				</div>
				<h1 class="bgin-display" style="font-size: 88px; margin-bottom: 28px;" {...page.edit.title}>
					{hero.headline} <em>{hero.emphasis}</em> {hero.after}
				</h1>
				<p class="bgin-lede" style="max-width: 580px;">{hero.lead}</p>
			</div>
			<div style="display: flex; flex-direction: column; gap: 16px; padding-bottom: 8px;">
				<span class="bgin-mono">Upcoming · {upcoming.length} events scheduled</span>
				<div style="display: flex; gap: 12px;">
					<a class="bgin-btn primary" href="#all-events">See all events</a>
					<a class="bgin-btn secondary" href="/working-groups">Working groups</a>
				</div>
			</div>
		</div>
	</section>

	{
		featured && (
			<section class="bgin-section bgin-band">
				<div style="max-width: 1200px; margin: 0 auto;">
					<span class="bgin-mono" style="margin-bottom: 24px; display: block;">
						● Featured upcoming event
					</span>
					<article
						class="bgin-featured-event-row"
					style="background: var(--canvas); border: 1px solid var(--rule); border-top: 3px solid var(--brand-blue); border-radius: 6px;"
					>
						<div style="text-align: center; border-right: 1px solid var(--rule); padding-right: 48px;">
							<div
								class="bgin-display"
								style="font-size: 96px; line-height: 0.95; color: var(--brand-blue);"
							>
								{featured.data.day_range || featured.data.date_day}
							</div>
							<span
								class="bgin-mono"
								style="margin-top: 8px; font-size: 13px; letter-spacing: 0.2em; color: var(--ink-soft);"
								>{featured.data.date_month} · {featured.data.date_year}</span
							>
							<span
								class="bgin-mono"
								style="margin-top: 6px; font-size: 11px; color: var(--ink-mute); display: block;"
								>{featured.data.time || "12:00 UTC"} · {featured.data.duration}</span
							>
						</div>
						<div>
							<span class="bgin-mono" style="margin-bottom: 12px; display: block; color: var(--brand-blue);">
								<span
									class="bgin-dot"
									style="background: var(--brand-blue); margin-right: 8px; animation: bgin-blink 2s var(--ease-standard) infinite;"
								/>
								{featured.data.kind}
							</span>
							<h2 class="bgin-h2" style="font-size: 40px; margin-bottom: 18px;">
								{featured.data.title}
							</h2>
							<p
								style="font-size: 16px; line-height: 1.65; color: var(--ink-soft); margin: 0; max-width: 580px;"
							>
								{featured.data.body}
							</p>
							<div style="display: flex; gap: 24px; margin-top: 24px;">
								<span class="bgin-mono">{featured.data.location} · {featured.data.duration}</span>
								<span class="bgin-mono">Free · open registration</span>
								<span class="bgin-mono" style="color: var(--ink-mute);">{featured.data.display_status}</span>
							</div>
						</div>
						<div style="text-align: right;">
							<a class="bgin-btn primary" href={`/events/${featured.id}`}>{featured.data.link_text || "Register"} →</a>
							<div style="margin-top: 16px;">
								<a class="bgin-arrow" href={`/events/${featured.id}`}>Event page <span aria-hidden="true">→</span></a>
							</div>
						</div>
					</article>
				</div>
			</section>
		)
	}

	<section id="all-events" class="bgin-section bgin-band">
		<div style="max-width: 1200px; margin: 0 auto;">
			<div
				style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 36px;"
			>
				<div>
					<div class="bgin-eyebrow" style="margin-bottom: 12px;">
						Upcoming · the field is gathering
					</div>
					<h2 class="bgin-h2" style="font-size: 40px;">All events <em>this season.</em></h2>
				</div>
				<span class="bgin-mono">{upcoming.length} scheduled · BGI Nexus public calendar</span>
			</div>
			<div style="background: var(--canvas); border: 1px solid var(--rule); border-radius: 6px;">
				{
					upcoming.map((event, index) => (
						<a
							href={`/events/${event.id}`}
							class="bgin-events-row"
					style={`border-bottom: ${index < upcoming.length - 1 ? "1px solid var(--rule)" : "0"}; text-decoration: none; color: inherit; transition: background 180ms var(--ease-standard);`}
						>
							<div>
								<div
									class="bgin-display"
									style={`font-size: 36px; line-height: 1; color: ${event.data.featured ? "var(--brand-blue)" : "var(--ink)"};`}
								>
									{event.data.day_range || event.data.date_day}
								</div>
								<span class="bgin-mono" style="margin-top: 4px; font-size: 11px; color: var(--ink-soft);">
									{event.data.date_month} '{String(event.data.date_year || "").slice(-2)}
								</span>
							</div>
							<span
								class="bgin-mono"
								style={`color: ${event.data.featured ? "var(--brand-blue)" : "var(--ink-soft)"};`}
								>{event.data.kind}</span
							>
							<div>
								<div
									style="font-family: var(--font-display); font-size: 22px; line-height: 1.15; color: var(--ink); margin-bottom: 4px;"
								>
									{event.data.title}
								</div>
								<span
									class="bgin-mono"
									style="font-size: 11px; color: var(--ink-mute); letter-spacing: 0.08em; text-transform: none;"
									>{event.data.host}</span
								>
							</div>
							<span
								class="bgin-mono"
								style="color: var(--ink-soft); text-transform: none; letter-spacing: 0.06em;"
							>
								{event.data.location} · {event.data.duration}
							</span>
							<span style="display: inline-flex; align-items: center; gap: 10px; justify-content: flex-end;">
								<span
									class="bgin-mono"
									style={`color: ${event.data.featured ? "var(--brand-blue)" : "var(--ink-mute)"};`}
								>
									{event.data.featured ? "● Featured" : event.data.display_status}
								</span>
								<span class="bgin-arrow" style="color: var(--brand-blue); pointer-events: none;">
									<span aria-hidden="true">→</span>
								</span>
							</span>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="bgin-section" style="padding-top: 64px; padding-bottom: 96px;">
		<div style="max-width: 1000px; margin: 0 auto; text-align: center;">
			<div class="bgin-eyebrow" style="margin-bottom: 16px; justify-content: center;">
				{subscribe.eyebrow}
			</div>
			<h2 class="bgin-h2" style="font-size: 40px; margin-bottom: 16px;">
				{subscribe.title} <em>{subscribe.emphasis}</em>
			</h2>
			<p class="bgin-lede" style="max-width: 520px; margin: 0 auto 28px;">
				{subscribe.body}
			</p>
			<form class="bgin-subscribe" style="margin: 0 auto; max-width: 480px;" data-subscribe-form>
				<input type="email" placeholder="you@your-domain.io" required />
				<button class="bgin-btn primary" type="submit">Subscribe</button>
			</form>
		</div>
	</section>

	<script>
		document.querySelectorAll("[data-subscribe-form]").forEach((form) => {
			form.addEventListener("submit", async (event) => {
				event.preventDefault();
				const emailInput = form.querySelector<HTMLInputElement>("input[type='email']");
				const button = form.querySelector<HTMLButtonElement>("button");
				const email = emailInput?.value?.trim() || "";
				if (!button) return;
				const original = button.textContent || "Subscribe";
				button.textContent = "Subscribing…";
				button.disabled = true;
				try {
					const res = await fetch("/api/subscribe", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ email }),
					});
					const data = await res.json();
					if (data.success) {
						button.textContent = "Subscribed ✓";
						if (emailInput) emailInput.value = "";
					} else {
						button.textContent = data.error || "Error — try again";
						setTimeout(() => { button.textContent = original; button.disabled = false; }, 3000);
						return;
					}
				} catch {
					button.textContent = "Error — try again";
					setTimeout(() => { button.textContent = original; button.disabled = false; }, 3000);
					return;
				}
				setTimeout(() => { button.textContent = original; button.disabled = false; }, 4000);
			});
		});
	</script>
</Base>
