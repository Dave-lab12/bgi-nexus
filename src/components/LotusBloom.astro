---
interface Props {
	strength?: "off" | "subtle" | "bloom" | string;
}

const { strength = "subtle" } = Astro.props;
const opacity = strength === "bloom" ? 0.55 : 0.22;
---

{
	strength !== "off" && (
		<div class="bgin-lotus" aria-hidden="true" style={`--lotus-strength: ${opacity};`}>
			<svg viewBox="-100 -100 200 200" xmlns="http://www.w3.org/2000/svg">
				<defs>
					<radialGradient id="lotus-bloom" cx="50%" cy="50%" r="50%">
						<stop offset="0%" stop-color="#E879F9" stop-opacity="0.65" />
						<stop offset="35%" stop-color="#A78BFA" stop-opacity="0.45" />
						<stop offset="65%" stop-color="#818CF8" stop-opacity="0.30" />
						<stop offset="100%" stop-color="#2DD4BF" stop-opacity="0" />
					</radialGradient>
				</defs>
				<circle cx="0" cy="0" r="98" fill="url(#lotus-bloom)" />
			</svg>
		</div>
	)
}
