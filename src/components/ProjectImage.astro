---
import { Image } from "emdash/ui";
import type { MediaValue } from "emdash";

interface Props {
	code?: string;
	tag?: string;
	title?: string;
	image?: MediaValue | string | null;
	large?: boolean;
}

const { code = "", tag = "", title = "", image = null, large = false } = Astro.props;
const ratio = large ? "21 / 9" : "16 / 10";
const hasImage =
	typeof image === "string" ? image.trim().length > 0 : Boolean(image?.id || image?.src);
const imageAlt = typeof image === "string" && title ? `${title} project image` : undefined;
const tagLabel = tag ? tag.toUpperCase() : "SPONSORED PROJECT";
const fallbackTitle = title || "BGI Nexus funded project";
const fallbackInitials =
	fallbackTitle
		.split(/[\s:.-]+/)
		.filter(Boolean)
		.slice(0, 2)
		.map((word) => word[0]?.toUpperCase())
		.join("") || code || "BGI";

const tagPalettes: Record<string, { accent: string; tint: string }> = {
	access: { accent: "#8d5fc4", tint: "rgba(141, 95, 196, 0.14)" },
	climate: { accent: "#2f8f83", tint: "rgba(47, 143, 131, 0.14)" },
	ecology: { accent: "#5f8c4d", tint: "rgba(95, 140, 77, 0.15)" },
	governance: { accent: "#367ba0", tint: "rgba(54, 123, 160, 0.14)" },
	health: { accent: "#b05f48", tint: "rgba(176, 95, 72, 0.14)" },
	language: { accent: "#b4872d", tint: "rgba(180, 135, 45, 0.16)" },
};
const palette = tagPalettes[tag.toLowerCase()] ?? {
	accent: "var(--brand-blue)",
	tint: "rgba(54, 123, 160, 0.14)",
};
---

<div
	class:list={["project-image", large && "project-image--large"]}
	style={`--project-ratio: ${ratio}; --project-accent: ${palette.accent}; --project-tint: ${palette.tint};`}
>
	{
		hasImage ? (
			<>
				<div class="project-image__media">
					<Image
						image={image}
						alt={imageAlt}
						style="display: block; width: 100%; height: 100%; object-fit: cover;"
					/>
				</div>
				<div class="project-image__shade" aria-hidden="true" />
			</>
		) : (
			<div class="project-image__fallback">
				<div class="project-image__mark" aria-hidden="true">
					{fallbackInitials}
				</div>
				<div class="project-image__fallback-copy">
					<strong>{fallbackTitle}</strong>
				</div>
			</div>
		)
	}
	<div class={`project-image__meta${hasImage ? " is-on-image" : ""}`}>
		<span class="bgin-mono">{tagLabel}</span>
		{code && <span class="bgin-mono">{code}</span>}
	</div>
</div>

<style>
	.project-image {
		aspect-ratio: var(--project-ratio);
		background: var(--canvas);
		border: 1px solid var(--rule);
		border-radius: 4px;
		overflow: hidden;
		position: relative;
	}

	.project-image__media,
	.project-image__shade,
	.project-image__fallback {
		position: absolute;
		inset: 0;
	}

	.project-image__media :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project-image__shade {
		background:
			linear-gradient(180deg, rgba(15, 18, 28, 0.46), rgba(15, 18, 28, 0) 42%),
			linear-gradient(0deg, rgba(15, 18, 28, 0.5), rgba(15, 18, 28, 0) 48%);
	}

	.project-image__fallback {
		background:
			linear-gradient(90deg, var(--project-accent) 0 6px, transparent 6px),
			var(--project-tint);
		display: grid;
		grid-template-rows: 1fr auto;
		padding: 18px;
	}

	.project-image__mark {
		align-items: center;
		align-self: center;
		background: rgba(255, 252, 246, 0.58);
		border: 1px solid rgba(31, 18, 71, 0.1);
		border-radius: 4px;
		color: var(--project-accent);
		display: inline-flex;
		font-family: var(--font-display);
		font-size: 46px;
		height: 96px;
		justify-content: center;
		letter-spacing: 0;
		line-height: 1;
		width: 96px;
	}

	.project-image--large .project-image__mark {
		font-size: 64px;
		height: 128px;
		width: 128px;
	}

	.project-image__fallback-copy {
		max-width: min(360px, 100%);
	}

	.project-image__fallback-copy strong {
		color: var(--ink);
		display: -webkit-box;
		font-family: var(--font-display);
		font-size: 19px;
		font-weight: 400;
		line-height: 1.12;
		overflow: hidden;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.project-image--large .project-image__fallback-copy strong {
		font-size: 28px;
	}

	.project-image__meta {
		display: flex;
		gap: 12px;
		justify-content: space-between;
		left: 16px;
		position: absolute;
		right: 16px;
		top: 14px;
	}

	.project-image__meta .bgin-mono {
		color: var(--ink-mute);
		font-size: 10px;
		letter-spacing: 0;
	}

	.project-image__meta.is-on-image .bgin-mono {
		color: rgba(255, 252, 246, 0.9);
		text-shadow: 0 1px 12px rgba(15, 18, 28, 0.4);
	}
</style>
