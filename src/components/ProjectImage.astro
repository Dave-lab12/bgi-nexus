---
interface Props {
	code?: string;
	tag?: string;
	large?: boolean;
}

const { code = "", tag = "", large = false } = Astro.props;
const ratio = large ? "21 / 9" : "16 / 10";
---

<div
	style={`aspect-ratio: ${ratio}; background: var(--canvas-shade); border-radius: 4px; border: 1px solid var(--rule); position: relative; overflow: hidden;`}
>
	<svg
		viewBox="0 0 100 100"
		preserveAspectRatio="xMidYMid slice"
		style="position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.5;"
		aria-hidden="true"
	>
		<g stroke="rgba(31,18,71,0.15)" stroke-width="0.12">
			<line x1="14" y1="22" x2="38" y2="44" />
			<line x1="38" y1="44" x2="62" y2="32" />
			<line x1="38" y1="44" x2="50" y2="68" />
			<line x1="62" y1="32" x2="84" y2="56" />
			<line x1="50" y1="68" x2="72" y2="82" />
			<line x1="22" y1="78" x2="50" y2="68" />
		</g>
		<g fill="rgba(31,18,71,0.4)">
			<circle cx="14" cy="22" r="0.9" />
			<circle cx="38" cy="44" r="1.0" />
			<circle cx="62" cy="32" r="0.9" />
			<circle cx="50" cy="68" r="1.0" />
			<circle cx="84" cy="56" r="0.9" />
			<circle cx="72" cy="82" r="0.8" />
			<circle cx="22" cy="78" r="0.8" />
		</g>
		<circle cx="38" cy="44" r="1.6" fill="var(--brand-blue)" />
	</svg>
	<span
		class="bgin-mono"
		style="position: absolute; top: 14px; left: 16px; font-size: 10px; color: var(--ink-mute); letter-spacing: 0.14em;"
	>
		{tag.toUpperCase()}
	</span>
	<span
		class="bgin-mono"
		style="position: absolute; top: 14px; right: 16px; font-size: 10px; color: var(--ink-mute); letter-spacing: 0.14em;"
	>
		{code}
	</span>
	<span
		class="bgin-mono"
		style="position: absolute; bottom: 14px; left: 16px; font-size: 10px; color: var(--ink-mute); letter-spacing: 0.06em; text-transform: none;"
	>
		Image · sourced from DF website
	</span>
</div>
