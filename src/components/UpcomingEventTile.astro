---
interface EventData {
	title?: string;
	date_day?: string;
	date_month?: string;
	date_year?: string;
	day_range?: string;
	location?: string;
	duration?: string;
	time?: string;
	host?: string;
	body?: string;
	display_status?: string;
	link_text?: string;
	link_url?: string;
}

interface Props {
	event?: { id?: string; data?: EventData } | EventData | null;
	kind?: "editorial" | "live" | string;
}

const { event = null, kind = "editorial" } = Astro.props;
const eventId = "id" in (event ?? {}) ? (event as { id?: string }).id : undefined;
const data = "data" in (event ?? {}) ? (event as { data: EventData }).data : (event as EventData | null);
const isLive = kind === "live";
const dateDay = data?.day_range || data?.date_day || "01";
const dateMonth = data?.date_month || "JUN";
const dateYear = data?.date_year || "2026";
const title = data?.title || "Healthy human-AI ecosystems";
const body =
	data?.body ||
	"Monthly community updates, grant progress, and open Q&A.";
const duration = data?.duration || "90 min";
const location = data?.location || "Virtual";
const time = data?.time || "12:00 UTC";
const eventHref = eventId ? `/events/${eventId}` : "/events";
const linkText = isLive ? "Register" : "View event";
const status = data?.display_status || "Free · open registration";
---

<a
	href={eventHref}
	class="bgin-event-tile"
	style="display: block; text-decoration: none; border: 1px solid var(--rule); border-top: 3px solid var(--brand-blue); border-radius: 6px; background: var(--canvas); padding: 28px; color: var(--ink); transition: transform 180ms var(--ease-standard), box-shadow 180ms var(--ease-standard);"
>
	<div
		style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px;"
	>
		<span
			class="bgin-eyebrow"
			style="display: inline-flex; align-items: center; gap: 8px;"
		>
			{
				isLive && (
					<span
						class="bgin-dot"
						style="animation: bgin-blink 2s var(--ease-standard) infinite;"
					/>
				)
			}
			Upcoming event
		</span>
		<span class="bgin-mono" style="color: var(--ink-mute);">{location}</span>
	</div>
	<div
		style="display: flex; align-items: baseline; gap: 16px; margin-bottom: 20px;"
	>
		<div
			class="bgin-display"
			style="font-size: 72px; line-height: 0.95; color: var(--brand-blue);"
		>
			{dateDay}
		</div>
		<div>
			<div
				style="font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft);"
			>
				{dateMonth} · {dateYear}
			</div>
			<div
				style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-mute); margin-top: 4px;"
			>
				{time} · {duration}
			</div>
		</div>
	</div>
	<h3
		style="font-family: var(--font-display); font-size: 32px; font-weight: 400; line-height: 1.1; margin: 0 0 14px; color: var(--ink); letter-spacing: -0.012em;"
	>
		{title}
	</h3>
	<p
		style="font-size: 14px; line-height: 1.6; color: var(--ink-soft); margin: 0 0 28px;"
	>
		{body}
	</p>
	<div
		style="display: flex; justify-content: space-between; align-items: center; padding-top: 18px; border-top: 1px solid var(--rule);"
	>
		{
			isLive ? (
				<>
					<span class="bgin-mono" style="color: var(--ink-mute);">
						<span
							class="bgin-dot"
							style="background: var(--brand-blue); margin-right: 8px;"
						/>
						{status}
					</span>
					<span class="bgin-arrow" style="pointer-events: none;">
						{linkText} <span aria-hidden="true">→</span>
					</span>
				</>
			) : (
				<>
					<span class="bgin-mono" style="color: var(--ink-mute);">
						{status}
					</span>
					<span class="bgin-arrow" style="pointer-events: none;">
						{linkText} <span aria-hidden="true">→</span>
					</span>
				</>
			)
		}
	</div>
</a>
