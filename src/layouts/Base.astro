---
import { getMenu, getSiteSettings } from "emdash";
import {
	EmDashBodyEnd,
	EmDashBodyStart,
	EmDashHead,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import "../styles/tokens.css";
import "../styles/bgi.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	active?: string | null;
	density?: "compact" | "comfortable" | "airy";
	italicAccent?: string;
	darkSurface?: string;
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	pageTitle,
	description,
	image,
	canonical,
	active = null,
	density = "comfortable",
	italicAccent = "#367BA0",
	darkSurface = "#0F1E3D",
	content,
} = Astro.props;

const { siteTitle, siteTagline, siteLogo, siteFavicon } = resolveStarterSiteIdentity(
	await getSiteSettings(),
);
const faviconUrl = siteFavicon ?? "/assets/bgi-nexus-logo-circle.jpg";
const ogImage = image ?? siteFavicon ?? `${Astro.url.origin}/assets/bgi-nexus-logo-circle.jpg`;
const fullTitle = title.includes(siteTitle) ? title : `${title} · ${siteTitle}`;
const pageDescription = description ?? siteTagline;
const menu = await getMenu("primary");
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const logoSrc = siteLogo?.url ?? "/assets/bgi-nexus-logo-circle.jpg";
const logoAlt = siteLogo?.alt || siteTitle;
const menuItems = menu?.items?.length
	? menu.items
	: [
			{ label: "About", url: "/about", target: undefined },
			{ label: "Events", url: "/events", target: undefined },
			{ label: "Working groups", url: "/working-groups", target: undefined },
			{
				label: "Sponsored projects",
				url: "/sponsored-projects",
				target: undefined,
			},
			{ label: "Contact", url: "/contact", target: undefined },
		];

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: "website",
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description: pageDescription,
	canonical,
	image,
	content,
	siteName: siteTitle,
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		{pageDescription && <meta name="description" content={pageDescription} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<!-- Favicon -->
		<link rel="icon" href={faviconUrl} type="image/jpeg" />
		<link rel="apple-touch-icon" href={faviconUrl} />
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteTitle} />
		<meta property="og:title" content={pageTitle ?? title} />
		{pageDescription && <meta property="og:description" content={pageDescription} />}
		<meta property="og:image" content={ogImage} />
		{canonical && <meta property="og:url" content={canonical} />}
		<!-- Twitter card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle ?? title} />
		{pageDescription && <meta name="twitter:description" content={pageDescription} />}
		<meta name="twitter:image" content={ogImage} />
		<EmDashHead page={pageCtx} />
	</head>
	<body class={`bgin-density-${density}`}>
		<EmDashBodyStart page={pageCtx} />

		<div
			class="bgin-page"
			style={`--italic-accent: ${italicAccent}; --italic-accent-dark: ${italicAccent}; --bg-impact: ${darkSurface};`}
		>
			<header>
				<nav class="bgin-nav">
					<a href="/" class="brand" style="text-decoration: none; border: 0;">
						<img src={logoSrc} alt={logoAlt} />
						<span class="brand-name">{siteTitle}</span>
					</a>
					<div class="links">
						{
							menuItems.map((item) => {
								const itemPath = item.url?.replace(/\/$/, "") || "/";
								const isActive = active === item.label || currentPath === itemPath;
								return (
									<a
										href={item.url}
										target={item.target}
										class={isActive ? "active" : undefined}
									>
										{item.label}
									</a>
								);
							})
						}
					</div>
					<a class="bgin-btn primary" href="/contact">
						Get involved →
					</a>
					<button class="bgin-nav-toggle" aria-label="Toggle menu" aria-expanded="false">
						<span></span>
						<span></span>
						<span></span>
					</button>
				</nav>

				<div class="bgin-nav-mobile" id="bgin-mobile-menu">
					{
						menuItems.map((item) => {
							const itemPath = item.url?.replace(/\/$/, "") || "/";
							const isActive = active === item.label || currentPath === itemPath;
							return (
								<a
									href={item.url}
									target={item.target}
									class={isActive ? "active" : undefined}
								>
									{item.label}
								</a>
							);
						})
					}
					<a class="bgin-btn primary" href="/contact">Get involved →</a>
				</div>
			</header>

			<main>
				<slot />
			</main>

			<footer class="bgin-footer">
				<div class="cols">
					<div>
						<div
							style="display: flex; align-items: center; gap: 12px; margin-bottom: 18px;"
						>
							<img
								src={logoSrc}
								alt=""
								style="width: 36px; height: 36px; border-radius: 999px;"
							/>
							<span
								style="font-family: var(--font-display); font-size: 18px; color: var(--ink-on-dark);"
								>{siteTitle}</span
							>
						</div>
						<p
							style="color: rgba(245, 239, 226, 0.65); font-size: 14px; line-height: 1.6; margin: 0 0 18px; max-width: 280px;"
						>
							Community-driven funding and infrastructure for building beneficial AI that serves humanity and our planet.
						</p>
						<span class="bgin-mono on-dark">Part of the SingularityNET ecosystem</span>
					</div>
					<div>
						<h5>Explore</h5>
						<ul>
							<li><a href="/events">Events</a></li>
							<li><a href="/sponsored-projects">Sponsored projects</a></li>
							<li><a href="/working-groups">Working groups</a></li>
							<li><a href="/about">About</a></li>
						</ul>
					</div>
					<div>
						<h5>Get involved</h5>
						<ul>
							<li><a href="https://mailchi.mp/singularitynet.io/x4xss53zgt">Newsletter</a></li>
							<li><a href="https://bgicollective.singularitynet.io/Discord">Discord</a></li>
							<li><a href="https://t.me/+8PKlTLYeQac4ZWVh">Telegram</a></li>
							<li><a href="https://www.linkedin.com/groups/12964136/">LinkedIn</a></li>
						</ul>
					</div>
					<div>
						<h5>Get in Touch</h5>
						<ul>
							<li>
								<a href="mailto:bginexus@singularitynet.io">
									Contact Us
								</a>
							</li>
							<li><a href="https://singularitynet.io">SingularityNET</a></li>
							<li><a href="https://singularitynet.io/cookies-and-privacy-policy/">Privacy Policy</a></li>
						</ul>
					</div>
				</div>
				<div class="meta">
					<span>© 2025 BGI Nexus. All rights reserved.</span>
					<span style="display: inline-flex; gap: 18px;">
						<a href="https://singularitynet.io" style="color: rgba(245,239,226,0.55);">SingularityNET</a>
						<a href="https://singularitynet.io/cookies-and-privacy-policy/" style="color: rgba(245,239,226,0.55);">Privacy Policy</a>
					</span>
				</div>
			</footer>
		</div>

		<EmDashBodyEnd page={pageCtx} />
		<script>
			const toggle = document.querySelector<HTMLButtonElement>(".bgin-nav-toggle");
			const mobileMenu = document.getElementById("bgin-mobile-menu");
			toggle?.addEventListener("click", () => {
				const open = toggle.getAttribute("aria-expanded") === "true";
				toggle.setAttribute("aria-expanded", String(!open));
				mobileMenu?.classList.toggle("open", !open);
				document.body.style.overflow = !open ? "hidden" : "";
			});
			mobileMenu?.querySelectorAll("a").forEach((a) => {
				a.addEventListener("click", () => {
					toggle?.setAttribute("aria-expanded", "false");
					mobileMenu.classList.remove("open");
					document.body.style.overflow = "";
				});
			});
		</script>
	</body>
</html>
