          "sections": {
            "hero": {
              "eyebrow": "Working groups",
              "headline": "From conversation",
              "emphasis": "to coordinated action.",
              "after": "",
              "lead": "The BGI Nexus working groups are built for people who want to move from conversation to coordinated action around practical topics for beneficial AGI."
            },
            "join": {
              "label": "\u203b What to expect",
              "title": "The kickoff opens",
              "emphasis": "the work.",
              "body": "The kickoff session introduces initial working-group topics, connects contributors with one another, and sets the next phase of collaboration for the BGI Nexus community.",
              "steps": [
                {
                  "num": "01",
                  "title": "Meet the community",
                  "body": "Connect with other members of the BGI Nexus community and learn where people are already contributing."
                },
                {
                  "num": "02",
                  "title": "Explore themes",
                  "body": "Discuss AGI for human flourishing, consciousness, and proactionary versus precautionary approaches to AGI."
                },
                {
                  "num": "03",
                  "title": "Find collaborators",
                  "body": "Match interests, skills, and questions with contributors who want to keep building after the session."
                },
                {
                  "num": "04",
                  "title": "Shape the next phase",
                  "body": "Help shape ongoing collaboration and quarterly meetups around the topics that gather momentum."
                }
              ]
            },
            "sprints": {
              "eyebrow": "Ongoing collaboration",
              "title": "Quarterly",
              "emphasis": "meetups.",
              "body": "Each topic is intended to expand into ongoing collaboration and quarterly meetups, giving the community a recurring rhythm for practical work.",
              "body_soft": "The kickoff session marks the beginning of a series of collaborative working groups focused on guiding and governing AGI toward beneficial outcomes for humanity."
            },
            "directory_note": "Kickoff session \u00b7 02 Dec 2025"
