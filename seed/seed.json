              "eyebrow": "\u203b BGI Nexus",
              "title": "Community-driven funding",
              "emphasis": "and infrastructure.",
              "body": "BGI Nexus provides community-driven funding and infrastructure for building beneficial AI that serves humanity and our planet.",
              "body_soft": "The initiative connects builders with resources, expertise, and a wider community so promising beneficial AI ideas can move from proposal to real-world impact.",
              "principles": [
                {
                  "word": "Funding",
                  "body": "Community-selected support for teams building beneficial AI projects."
                },
                {
                  "word": "Expertise",
                  "body": "A practical network for mentorship, review, and shared learning."
                },
                {
                  "word": "Community",
                  "body": "Open channels, events, and working groups for people ready to contribute."
                }
              ]
            },
            "pillars": {
              "eyebrow": "How the nexus works",
              "title": "Funding, expertise,",
              "emphasis": "and community.",
              "items": [
                {
                  "num": "01",
                  "title": "Sponsored projects",
                  "count": "10",
                  "label": "funded teams \u00b7 Round 01",
                  "body": "Ten community-selected projects received support to build beneficial AI in health, climate, accessibility, governance, and regenerative systems."
                },
                {
                  "num": "02",
                  "title": "Community events",
                  "count": "03",
                  "label": "public sessions listed",
                  "body": "Community calls and working-group meetups create space for grant progress, updates, open Q&A, and practical collaboration."
                },
                {
                  "num": "03",
                  "title": "Global contributors",
                  "count": "953",
                  "label": "contributors in the network",
                  "body": "BGI Nexus brings together builders, researchers, funders, and community members around beneficial AI that serves humanity and the planet."
                }
              ]
            },
            "working_groups": {
              "intro": "The BGI Nexus working groups are built for people who want to move from conversation to coordinated action, bringing contributors together around practical topics for guiding and governing AGI toward beneficial outcomes."
            },
            "events": {
              "intro": "Monthly community updates, grant progress, open Q&A, and working-group sessions for people building beneficial AI."
            },
