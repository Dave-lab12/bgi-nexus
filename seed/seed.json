        "id": "about",
        "slug": "about",
        "status": "published",
        "data": {
          "title": "About",
          "content": [],
          "sections": {
            "hero": {
              "eyebrow": "About BGI Nexus",
              "headline": "Where Beneficial AI",
              "emphasis": "Gets Built."
            },
            "what": {
              "label": "01 \u00b7 General information",
              "title": "What is",
              "emphasis": "BGI Nexus?",
              "body": "BGI Nexus is community-driven funding and infrastructure for building beneficial AI that serves humanity and our planet.",
              "body_soft": "From idea to impact, BGI Nexus connects builders with funding, expertise, and community to turn beneficial AI projects into reality."
            },
            "principles": {
              "label": "02 \u00b7 What the community supports",
              "title": "Beneficial AI",
              "emphasis": "in practice.",
              "body": "The funded cohort shows the breadth of beneficial AI in practice: climate resilience, carbon-credit trust, glucose-data ownership, regenerative biodiversity, accessibility, community governance, agricultural knowledge, and ecological knowledge preservation.",
              "items": [
                {
                  "word": "Humanity",
                  "body": "Projects are selected for practical benefit to people, communities, and public-good systems."
                },
                {
                  "word": "Planet",
                  "body": "Several teams focus on climate resilience, biodiversity, carbon trust, and regenerative ecological knowledge."
                },
                {
                  "word": "Access",
                  "body": "The cohort includes language access, inclusive conferencing, and sign-language translation for underserved communities."
                },
                {
                  "word": "Ownership",
                  "body": "Projects explore community agency, open health data, and democratic decision-making tools."
                },
                {
                  "word": "Impact",
                  "body": "BGI Nexus emphasizes moving from proposals and discussion into funded, measurable work."
                }
              ]
            },
            "spiral": {
              "lotus": "subtle",
              "label": "03 \u00b7 Ecosystem",
              "title": "Part of the",
              "emphasis": "SingularityNET ecosystem.",
              "body": "BGI Nexus is part of the SingularityNET ecosystem, connecting beneficial AI builders with the people and infrastructure needed to move from idea to impact.",
              "body_soft": "The public channels, events, and newsletter help community members follow grant rounds, funded projects, and opportunities to contribute.",
              "primary_label": "View projects",
              "primary_url": "/sponsored-projects",
              "secondary_label": "Stay connected",
